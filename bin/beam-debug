#!/usr/bin/env bash
set -euo pipefail

SELF="$(readlink -f -- "${BASH_SOURCE[0]}")"
ROOT="$(CDPATH= cd -- "$(dirname -- "$SELF")/.." && pwd)"
GUARD="$ROOT/hooks/stop_guard.py"
JOURNAL="$ROOT/lib/journal.py"
MANAGER="$ROOT/lib/manage_install.py"
HELPER="$ROOT/support/beam_debug.exs"
PROBE_TRACE="$ROOT/support/probe_trace.exs"
PROBE_SNAPSHOT="$ROOT/support/probe_snapshot.exs"
PACKAGE_VERSION="$(cat -- "$ROOT/VERSION" 2>/dev/null || printf '0.0.0')"

usage() {
  cat <<'USAGE'
Usage: beam-debug <command> [args]

Run tests:
  test [mix-test-args...]     Plain `mix test` passthrough (no implicit --trace)
  pry-test [mix-test-args...] Interactive `iex -S mix test --trace` with helpers
                              preloaded. --trace is added deliberately here: it
                              disables test timeouts so IEx.pry is usable. It
                              also sets --max-cases 1, so do not use it to
                              investigate cross-test concurrency failures.

Observe without editing source:
  trace <target> [opts] [-- mix ...]
                              Bounded call trace of an MFA target, installed
                              synchronously before the command runs.
                              target: Mod | Mod.fun | Mod.fun/arity
                                      :mod | :mod.fun | :mod.fun/arity (Erlang)
                              opts:  --limit N (default 200; stops at event N)
                                     --for MS  (also stop after MS ms)
                                     --replace-tracer (take over a tracer that
                                                       existed before the probe;
                                                       never done silently)
  snapshot [opts] [-- mix ...]
                              Run a command with a watchdog that dumps process
                              state, mailboxes, current stacktraces, links,
                              monitors and a blocked-process census at a chosen
                              time.
                              opts:  --after MS        (default 5000, measured
                                                        from the start of the
                                                        wrapped task, after
                                                        compilation)
                                     --names A,B       (only these registered
                                                        names get :sys probes)
                                     --supervisors A,B (only these are asked
                                                        for their children)
                                     --top N           (default 10, by queue
                                                        length)

Temporary inline markers (Elixir `# BEAMDBG`, Erlang `% BEAMDBG`):
  begin                       Start a session-owned marker ledger; prints the
                              token to embed in markers (# BEAMDBG:<token>).
                              An installed Stop hook checks only markers
                              owned by its own agent session.
  end [token]                 Verify this session's markers are gone — in
                              committed content too — then drop the ledger
  scan                        Whole-worktree audit: list anyone's newly-added
                              BEAMDBG markers
  assert-clean                Exit nonzero when newly-added markers remain
                              (whole-worktree audit, human-invoked)

Evidence journal (optional, per repository):
  note <text> [--status open|confirmed|killed] [--evidence TEXT]
  history [--limit N]         Print journal entries, newest last
  report                      Summarize journal hypotheses by status

Other:
  doctor                      Check the local install, BEAM toolchain, and
                              this project's minimum-version requirement
  init-project                Mark this repository as using elixir-agent-debug:
                              writes .beam-debug.toml (a minimum-version
                              floor) and short pointer notes into the project
                              CLAUDE.md and AGENTS.md. Adds no project-local
                              hooks, skills, or executables — those stay
                              user-level by design.
  iex [mix-args...]           Run `iex -S mix ...` with helpers preloaded
  capture -- <command...>     Run inline and tee output to a per-repo latest.log
  latest                      Print the latest captured log for this repo
  help                        Show this help
USAGE
}

repo_identity() {
  local root
  root="$(git rev-parse --show-toplevel 2>/dev/null || pwd -P)"
  printf '%s' "$root" | sha256sum | cut -c1-16
}

state_dir() {
  local base key
  base="${XDG_STATE_HOME:-$HOME/.local/state}/beam-debug"
  key="$(repo_identity)"
  printf '%s/%s\n' "$base" "$key"
}

log_path() {
  printf '%s/latest.log\n' "$(state_dir)"
}

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'beam-debug: required command not found: %s\n' "$1" >&2
    exit 127
  fi
}

# --- per-project manifest (.beam-debug.toml) ---------------------------------
# A checked-in floor, not a vendored install: the executable, skill and hook
# always come from the user-level installation. The manifest only states the
# minimum version this project expects.

project_manifest() {
  local root
  root="$(git rev-parse --show-toplevel 2>/dev/null)" || return 1
  [[ -f "$root/.beam-debug.toml" ]] || return 1
  printf '%s/.beam-debug.toml\n' "$root"
}

# manifest_value <file> <key> — tolerant `key = "value"` reader
manifest_value() {
  sed -n "s/^[[:space:]]*$2[[:space:]]*=[[:space:]]*[\"']\{0,1\}\([^\"'#]*\)[\"']\{0,1\}.*/\1/p" "$1" \
    | head -1 | tr -d '[:space:]'
}

# floor_satisfied <minimum> — true when PACKAGE_VERSION >= minimum
floor_satisfied() {
  [[ "$(printf '%s\n%s\n' "$1" "$PACKAGE_VERSION" | sort -V | head -1)" == "$1" ]]
}

# manifest_floor <file> — prints the required minimum version; prints nothing
# when the check is disabled. A requirement manifest fails closed: anything
# other than enabled = true|false, or a non-version minimum, is an error.
manifest_floor() {
  local file="$1" enabled minimum
  enabled="$(manifest_value "$file" enabled)"
  case "$enabled" in
    false)
      return 0
      ;;
    true)
      ;;
    *)
      printf 'beam-debug: malformed %s: `enabled` must be true or false (got: %s)\n' \
        "$file" "${enabled:-<missing>}" >&2
      return 3
      ;;
  esac
  minimum="$(manifest_value "$file" minimum_version)"
  if ! [[ "$minimum" =~ ^[0-9]+(\.[0-9]+)*$ ]]; then
    printf 'beam-debug: malformed %s: `minimum_version` must be a plain version like "1.4.0" (got: %s)\n' \
      "$file" "${minimum:-<missing>}" >&2
    return 3
  fi
  printf '%s\n' "$minimum"
}

require_project_floor() {
  local manifest minimum
  manifest="$(project_manifest)" || return 0
  minimum="$(manifest_floor "$manifest")" || exit 3
  [[ -n "$minimum" ]] || return 0
  if ! floor_satisfied "$minimum"; then
    printf 'beam-debug: this project requires elixir-agent-debug >= %s; installed is %s.\n' \
      "$minimum" "$PACKAGE_VERSION" >&2
    printf 'Upgrade the user-level install: pull the latest elixir-agent-debug and rerun ./install.sh\n' >&2
    printf '(https://github.com/nshkrdotcom/elixir_agent_debug — see %s)\n' "$manifest" >&2
    exit 3
  fi
}

init_project() {
  need git
  need python3
  local root
  root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    printf 'beam-debug init-project: not inside a git worktree.\n' >&2
    exit 2
  }

  local manifest="$root/.beam-debug.toml"
  if [[ -f "$manifest" ]]; then
    # Refreshing the notes with an older template would silently downgrade
    # the project guidance: initialize-only when the floor is not met.
    local minimum
    minimum="$(manifest_floor "$manifest")" || exit 3
    if [[ -n "$minimum" ]] && ! floor_satisfied "$minimum"; then
      printf 'beam-debug init-project: this project already requires >= %s; installed is %s.\n' \
        "$minimum" "$PACKAGE_VERSION" >&2
      printf 'Refusing to rewrite the project notes with an older template. Upgrade first:\n' >&2
      printf 'pull the latest elixir-agent-debug and rerun ./install.sh\n' >&2
      exit 3
    fi
    printf 'Manifest already present: %s (minimum_version %s)\n' \
      "$manifest" "${minimum:-disabled}"
  else
    printf 'enabled = true\nminimum_version = "%s"\n' "$PACKAGE_VERSION" > "$manifest"
    printf 'Wrote %s (minimum_version = "%s")\n' "$manifest" "$PACKAGE_VERSION"
  fi

  python3 "$MANAGER" block-add "$root/CLAUDE.md" "$ROOT/adapters/project-instructions.md"
  python3 "$MANAGER" block-add "$root/AGENTS.md" "$ROOT/adapters/project-instructions.md"
  printf 'Added the project note to %s and %s (idempotent; safe to rerun).\n' \
    "$root/CLAUDE.md" "$root/AGENTS.md"
  printf 'Commit .beam-debug.toml, CLAUDE.md and AGENTS.md to share this with the team.\n'
  printf 'Nothing project-local was installed: the executable, skill and optional\n'
  printf 'Stop hook stay user-level (see README: Per-project setup).\n'
}

doctor() {
  local failed=0
  printf 'elixir-agent-debug root: %s\n' "$ROOT"
  printf 'version: %s\n' "$PACKAGE_VERSION"

  for command in bash python3 git sha256sum; do
    if command -v "$command" >/dev/null 2>&1; then
      printf 'ok: %-10s %s\n' "$command" "$(command -v "$command")"
    else
      printf 'missing: %s\n' "$command"
      failed=1
    fi
  done

  for command in elixir mix iex; do
    if command -v "$command" >/dev/null 2>&1; then
      printf 'ok: %-10s %s\n' "$command" "$(command -v "$command")"
    else
      printf 'missing for BEAM use: %s\n' "$command"
      failed=1
    fi
  done

  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'ok: git repo   %s\n' "$(git rev-parse --show-toplevel)"
  else
    printf 'note: current directory is not inside a git worktree; marker scanning is inactive here.\n'
  fi

  local manifest minimum enabled
  if manifest="$(project_manifest)"; then
    enabled="$(manifest_value "$manifest" enabled)"
    minimum="$(manifest_value "$manifest" minimum_version)"
    if [[ "$enabled" == "false" ]]; then
      printf 'note: project manifest present but disabled: %s\n' "$manifest"
    elif [[ "$enabled" != "true" ]]; then
      printf 'FAIL: malformed %s: `enabled` must be true or false (got: %s)\n' \
        "$manifest" "${enabled:-<missing>}"
      failed=1
    elif ! [[ "$minimum" =~ ^[0-9]+(\.[0-9]+)*$ ]]; then
      printf 'FAIL: malformed %s: `minimum_version` must be a plain version like "1.4.0" (got: %s)\n' \
        "$manifest" "${minimum:-<missing>}"
      failed=1
    elif floor_satisfied "$minimum"; then
      printf 'ok: project floor %s (installed %s)\n' "$minimum" "$PACKAGE_VERSION"
    else
      printf 'FAIL: this project requires >= %s but %s is installed; pull the latest and rerun ./install.sh\n' \
        "$minimum" "$PACKAGE_VERSION"
      failed=1
    fi
  else
    printf 'note: no project manifest; `beam-debug init-project` records a version floor for a team.\n'
  fi

  printf 'claude skill: %s\n' "$HOME/.claude/skills/elixir-debug/SKILL.md"
  printf 'codex skill:  %s\n' "$HOME/.agents/skills/elixir-debug/SKILL.md"
  printf 'state dir:    %s\n' "$(state_dir)"

  return "$failed"
}

capture() {
  need tee
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  if [[ $# -eq 0 ]]; then
    printf 'beam-debug capture: missing command\n' >&2
    exit 2
  fi

  local output status
  output="$(log_path)"
  mkdir -p -- "$(dirname -- "$output")"
  printf '$' | tee "$output"
  printf ' %q' "$@" | tee -a "$output"
  printf '\n' | tee -a "$output"

  set +e
  "$@" 2>&1 | tee -a "$output"
  status=${PIPESTATUS[0]}
  set -e
  printf '\n[exit %d] log: %s\n' "$status" "$output" | tee -a "$output"
  return "$status"
}

# require_int <option> <value> <minimum>
require_int() {
  if ! [[ "${2-}" =~ ^[0-9]+$ ]]; then
    printf 'beam-debug: %s needs a nonnegative integer, got: %s\n' "$1" "${2:-<empty>}" >&2
    exit 2
  fi
  if (( 10#$2 < $3 )); then
    printf 'beam-debug: %s must be at least %s\n' "$1" "$3" >&2
    exit 2
  fi
}

# Split "<opts...> [-- <command...>]" and run the command through a probe Mix
# task (`mix beam_debug.trace <task> <args>`), so instrumentation is installed
# after compilation but before the wrapped task starts. Defaults to `mix test`
# when no explicit command is given.
run_with_probe() {
  local task="$1" probe="$2"
  shift 2
  need elixir
  need mix

  local -a command=()
  local seen_separator=0
  for argument in "$@"; do
    if [[ "$seen_separator" -eq 1 ]]; then
      command+=("$argument")
    elif [[ "$argument" == "--" ]]; then
      seen_separator=1
    fi
  done
  if [[ "${#command[@]}" -eq 0 ]]; then
    command=(mix test)
  fi
  if [[ "${command[0]}" != "mix" ]]; then
    printf 'beam-debug: the wrapped command must start with `mix` (got: %s)\n' "${command[0]}" >&2
    exit 2
  fi

  local -a wrapped=("${command[@]:1}")
  if [[ "${#wrapped[@]}" -eq 0 ]]; then
    wrapped=(test)
  fi
  # The probe task wraps the real one, so `mix test`'s own env inference never
  # runs; set the env it would have chosen.
  if [[ "${wrapped[0]}" == "test" ]]; then
    export MIX_ENV="${MIX_ENV:-test}"
  fi

  exec elixir -r "$HELPER" -r "$probe" -S mix "$task" "${wrapped[@]}"
}

trace() {
  local target="" limit=200 duration=0 replace=""
  if [[ $# -eq 0 || "$1" == "--" || "$1" == --* ]]; then
    printf 'beam-debug trace: missing target (Mod | Mod.fun | Mod.fun/arity | :mod.fun/arity)\n' >&2
    exit 2
  fi
  target="$1"
  shift

  local -a rest=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit) require_int --limit "${2-}" 1; limit="$2"; shift 2 ;;
      --for) require_int --for "${2-}" 0; duration="$2"; shift 2 ;;
      --replace-tracer) replace=1; shift ;;
      --) rest=("$@"); break ;;
      *) printf 'beam-debug trace: unknown option: %s\n' "$1" >&2; exit 2 ;;
    esac
  done

  export BEAM_DEBUG_TRACE_TARGET="$target"
  export BEAM_DEBUG_TRACE_LIMIT="$limit"
  export BEAM_DEBUG_TRACE_FOR="$duration"
  export BEAM_DEBUG_TRACE_REPLACE="$replace"
  run_with_probe beam_debug.trace "$PROBE_TRACE" "${rest[@]+"${rest[@]}"}"
}

snapshot() {
  local after=5000 names="" top=10 supervisors=""
  local -a rest=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --after) require_int --after "${2-}" 0; after="$2"; shift 2 ;;
      --names) names="${2:?--names needs a value}"; shift 2 ;;
      --supervisors) supervisors="${2:?--supervisors needs a value}"; shift 2 ;;
      --top) require_int --top "${2-}" 0; top="$2"; shift 2 ;;
      --) rest=("$@"); break ;;
      *) printf 'beam-debug snapshot: unknown option: %s\n' "$1" >&2; exit 2 ;;
    esac
  done

  export BEAM_DEBUG_SNAPSHOT_AFTER="$after"
  export BEAM_DEBUG_SNAPSHOT_NAMES="$names"
  export BEAM_DEBUG_SNAPSHOT_SUPERVISORS="$supervisors"
  export BEAM_DEBUG_SNAPSHOT_TOP="$top"
  run_with_probe beam_debug.snapshot "$PROBE_SNAPSHOT" "${rest[@]+"${rest[@]}"}"
}

command="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

# The floor check protects real work, never recovery: help/doctor diagnose
# the situation, and end/scan/assert-clean/latest let an under-versioned
# install still clean up its own markers and read what it already captured.
# init-project performs its own check so it can refuse a downgrade precisely.
case "$command" in
  help|-h|--help|doctor|init-project|end|scan|assert-clean|latest) : ;;
  *) require_project_floor ;;
esac

case "$command" in
  doctor)
    doctor
    ;;
  init-project)
    init_project
    ;;
  test)
    need mix
    exec mix test "$@"
    ;;
  pry-test)
    need iex
    need mix
    exec iex -r "$HELPER" -S mix test --trace "$@"
    ;;
  itest)
    printf 'beam-debug: `itest` is renamed to `pry-test`; running pry-test.\n' >&2
    need iex
    need mix
    exec iex -r "$HELPER" -S mix test --trace "$@"
    ;;
  iex)
    need iex
    need mix
    exec iex -r "$HELPER" -S mix "$@"
    ;;
  trace)
    trace "$@"
    ;;
  snapshot)
    snapshot "$@"
    ;;
  capture)
    capture "$@"
    ;;
  latest)
    file="$(log_path)"
    if [[ ! -f "$file" ]]; then
      printf 'beam-debug: no captured log for this repository: %s\n' "$file" >&2
      exit 1
    fi
    cat -- "$file"
    ;;
  note|history|report)
    need python3
    exec python3 "$JOURNAL" "$command" --state-dir "$(state_dir)" "$@"
    ;;
  begin)
    need python3
    exec python3 "$GUARD" --begin "$@"
    ;;
  end)
    need python3
    exec python3 "$GUARD" --end "$@"
    ;;
  scan)
    need python3
    exec python3 "$GUARD" --scan
    ;;
  assert-clean)
    need python3
    exec python3 "$GUARD" --assert-clean
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    printf 'beam-debug: unknown command: %s\n\n' "$command" >&2
    usage >&2
    exit 2
    ;;
esac
